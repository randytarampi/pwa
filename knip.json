{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreWorkspaces": ["packages/asset-service"],
  "workspaces": {
    "packages/*": {
      "entry": ["package.json"],
      "ignore": [
        "coverage/**",
        ".nyc_output/**",
        "dist/**",
        "build/**",
        "packages/*/coverage/**",
        "packages/*/.nyc_output/**",
        "packages/*/dist/**",
        "packages/*/build/**",
        "packages/*/test/**",
        "packages/*/tests/**",
        "packages/asset-service/**"
      ]
    }
  }
}
